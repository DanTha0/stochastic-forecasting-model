# Copy this file to `.env` and fill in your Alpaca credentials.
# DO NOT COMMIT `.env` (keep secrets local).
#
# Alpaca credentials
ALPACA_API_KEY="YOUR_KEY_HERE"
ALPACA_API_SECRET="YOUR_SECRET_HERE"
#
# Base URL (paper vs live trading)
# Examples (verify in Alpaca docs / your account settings):
# - Paper trading base URL
# - Live trading base URL
ALPACA_BASE_URL="https://paper-api.alpaca.markets"
#
# Market data feed (availability depends on your Alpaca plan)
# Common values: "iex", "sip"
ALPACA_DATA_FEED="iex"
